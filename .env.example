# ===== Angel One SmartAPI Credentials =====
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=D12345
ANGEL_PASSWORD=1234
ANGEL_TOTP_SECRET=BASE32SECRETFROMANGEL

# ===== Trading Mode =====
# paper = simulated trades with real market data
# live  = real orders on Angel One (USE WITH CAUTION)
TRADING_MODE=paper

# ===== Capital & Risk =====
INITIAL_CAPITAL=500000
MAX_LOSS_PER_DAY=15000
SLIPPAGE_PCT=0.05

# ===== Strategy Parameters =====
# Minimum premium skew ratio to trigger a trade (default 2.0)
MIN_SKEW_RATIO=2.0
# OTM offset from ATM in points (default 50)
OTM_OFFSET=50
# Iron condor wing width in points (default 100)
WING_WIDTH=100
# Stop-loss multiplier on premium (default 2.0)
SL_MULTIPLIER=2.0

# ===== VIX Filter =====
VIX_MIN=12
VIX_MAX=18

# ===== Schedule =====
# Entry time (24h format, IST)
ENTRY_HOUR=14
ENTRY_MINUTE=0
# Hard exit time
EXIT_HOUR=15
EXIT_MINUTE=15

# ===== Monitoring Interval (seconds) =====
MONITOR_INTERVAL=30
